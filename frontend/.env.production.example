# Production Environment Variables
# Copy this file to .env.production and fill in the values

# Backend API URL (set this to your Railway backend URL or custom domain)
# This is required at BUILD TIME for React apps
REACT_APP_BASE_API_URL=https://your-backend-service.railway.app

# n8n webhook URL for receipt parsing (find this in your n8n Webhook node)
REACT_APP_N8N_WEBHOOK_URL=https://primary-production-0fe8e.up.railway.app/webhook/your-webhook-id
