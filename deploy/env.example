# DaRoomate Production Environment Variables
# Copy this file to .env and fill in the values

# ===========================================
# Database Configuration
# ===========================================
# For Railway PostgreSQL, these are auto-populated
# For external DB (AWS RDS, etc.), fill manually
POSTGRESQL_HOST=your-db-host.railway.internal
POSTGRESQL_PORT=5432
POSTGRESQL_DATABASE=daroomate
POSTGRESQL_USERNAME=postgres
POSTGRESQL_PASSWORD=your-secure-password

# Budget Database (shared with n8n)
BUDGET_DB_HOST=your-budget-db-host.railway.internal
BUDGET_DB_PORT=5432
BUDGET_DB_NAME=daroomate_budget
BUDGET_DB_USERNAME=postgres
BUDGET_DB_PASSWORD=your-secure-budget-password

# ===========================================
# Application Configuration
# ===========================================
# JWT secret key (minimum 32 characters for HS256)
JWT_KEY=your-super-secret-jwt-key-at-least-32-chars

# Spring profile
ACTIVE_PROFILE=prod

# Backend port
BACKEND_PORT=8085

# CORS - comma-separated list of allowed frontend origins
CORS_ALLOWED_ORIGINS=https://your-frontend.railway.app,http://localhost:3000

# ===========================================
# Email Configuration (SMTP) - Optional
# ===========================================
# If not configured, email notifications will be disabled (no-op)
# EMAIL_HOST and other email vars default to empty strings
# To enable email, fill in all fields below:
EMAIL_HOST=smtp.gmail.com
EMAIL_PORT=587
EMAIL_ID=your-app-email@gmail.com
# For Gmail, use an App Password, not your regular password
EMAIL_PASSWORD=your-app-password

# ===========================================
# Redis Configuration (optional — rate limiting fails open without it)
# ===========================================
# Railway: attach a Redis plugin and REDIS_URL is auto-populated
REDIS_URL=redis://localhost:6379

# ===========================================
# Frontend Configuration
# ===========================================
# Backend API URL - this is baked into the React build
REACT_APP_BASE_API_URL=https://your-backend.railway.app

# Frontend port (for local testing)
FRONTEND_PORT=3000
