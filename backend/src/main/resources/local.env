# Database
export POSTGRESQL_HOST=localhost
export POSTGRESQL_PORT=5432
export POSTGRESQL_DATABASE=daroomate
export POSTGRESQL_USERNAME=your_username
export POSTGRESQL_PASSWORD=your_password

export JWT_KEY=your-secret-key-at-least-32-chars

export EMAIL_HOST=smtp.gmail.com
export EMAIL_PORT=587
export EMAIL_ID=your-email@gmail.com
export EMAIL_PASSWORD=your-app-password

# CORS
# Local dev:
export CORS_ALLOWED_ORIGINS=http://localhost:3000,http://127.0.0.1:3000
# Production (set this in Railway Variables, not here):
# export CORS_ALLOWED_ORIGINS=https://theroommate-production.up.railway.app